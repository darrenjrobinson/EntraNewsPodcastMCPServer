# Required for generating embeddings during ingestion (semantic search).
# Ingestion still works without it — keyword (BM25) search only.
OPENAI_API_KEY=sk-...

# Optional: Override the ingest output database path (default: ./entra-news-podcasts.db)
# INGEST_DB_PATH=/path/to/entra-news-podcasts.db

# Optional (server runtime): use a local database instead of downloading from GitHub Releases
# ENTRA_PODCAST_DB_PATH=/path/to/entra-news-podcasts.db
